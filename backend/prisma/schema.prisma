generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

enum CharacterStatus {
  ALIVE
  DEAD
  UNKNOWN
}

enum CharacterGender {
  MALE
  FEMALE
  UNKNOWN
}

model Character {
  id          String           @id @default(uuid())
  image       String
  name        String
  status      CharacterStatus
  gender      CharacterGender
  description String
}
