generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CharacterStatus {
  ALIVE
  DEAD
  UNKNOWN
}

enum CharacterGender {
  MALE
  FEMALE
  UNKNOWN
}

model Character {
  id          String          @id @default(uuid())
  image       String
  name        String
  status      CharacterStatus
  gender      CharacterGender
  description String
}
